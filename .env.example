# =============================================================================
# Lazarus — Environment Template
# =============================================================================
# Copy this file to `.env` at the repo root before running Docker Compose or
# app services. Never commit `.env` (see `.gitignore`).
#
# Host vs Docker network:
#   - Values like `kafka:9092` are for containers on the `lazarus-mesh` network.
#   - From your laptop (curl, k6, local NestJS), use `localhost` + host ports.
# =============================================================================

# ── Compose / project ────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=lazarus

# ── Host port mappings (docker-compose publishes these to localhost) ─────────
KAFKA_HOST_PORT=9092
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
ORCHESTRATOR_HOST_PORT=3001
REMEDIATION_ENGINE_HOST_PORT=8000

# ── Kafka (infra + apps) ─────────────────────────────────────────────────────
# Inside Compose network (orchestrator, remediation-engine containers):
KAFKA_BROKERS=kafka:9092
# From host-only tools (optional override — uncomment when running apps locally):
# KAFKA_BROKERS=localhost:9092

KAFKA_CLIENT_ID=lazarus-orchestrator
KAFKA_ANOMALY_TOPIC=infrastructure-anomalies
KAFKA_RESULTS_TOPIC=remediation-results
KAFKA_ANOMALY_PARTITIONS=6

# Kafka JVM heap for single-node KRaft (512 MB per Master Plan §4 VPS budget)
KAFKA_HEAP_OPTS=-Xmx512m -Xms512m

# Python consumer (Phase 1+)
KAFKA_CONSUMER_GROUP=remediation-workers

# ── Redis / Valkey-compatible ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Host override for local dev outside Compose:
# REDIS_URL=redis://localhost:6379

REDIS_STREAM_VALIDATED=validated-remediations
REDIS_CONSUMER_GROUP_SANDBOX=sandbox-workers
REDIS_EVENTS_CHANNEL=lazarus:events
REDIS_STREAM_MAXLEN=10000

# ── NestJS orchestrator (Phase 1+) ───────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Docker socket — orchestrator only (Phase 3 sandbox)
DOCKER_HOST=unix:///var/run/docker.sock

# NestJS libuv thread pool (Phase 5 load tuning)
UV_THREADPOOL_SIZE=16

# Rate limiting — 100 req/s per IP default (§12)
THROTTLE_TTL=1000
THROTTLE_LIMIT=100

# CORS for Vercel dashboard (Phase 4) — comma-separated origins
FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Python remediation-engine (Phase 1+) ───────────────────────────────────
REMEDIATION_ENGINE_PORT=8000
REMEDIATION_ENGINE_HOST=0.0.0.0

# ── LLM — Google Gemini (Master Plan §4, 100% OSS/free-tier policy) ─────────
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash-lite
# Set true during k6 chaos tests to skip real LLM calls (§10, Q2)
LLM_MOCK=false
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# ── Sandbox execution (Phase 3 — orchestrator reads these) ───────────────────
SANDBOX_IMAGE=alpine:3.19
SANDBOX_MEMORY_BYTES=52428800
SANDBOX_NANO_CPUS=200000000
SANDBOX_TIMEOUT_MS=3000
SANDBOX_NETWORK_MODE=none

# ── Prometheus (infra) ───────────────────────────────────────────────────────
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Orchestrator metrics scrape target (Phase 4 — used in prometheus.yml)
ORCHESTRATOR_METRICS_URL=http://orchestrator:3001/metrics

# ── Grafana (infra) ──────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_ROOT_URL=http://localhost:3000

# ── Dashboard / frontend (Phase 4 — Next.js on Vercel) ───────────────────────
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3001
NEXT_PUBLIC_ORCHESTRATOR_DOCS_URL=http://localhost:3001/api/docs
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001/events

# ── Load testing (Phase 5 — k6) ──────────────────────────────────────────────
BASE_URL=http://localhost:3001
K6_VUS_MAX=5000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
