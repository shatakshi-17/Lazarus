{
  "compilerOptions": {
    // ── Module system & output ──────────────────────────────────────────────
    // "commonjs" = Node.js require/module.exports (Nest default on Node).
    "module": "commonjs",
    // Emit .d.ts type declaration files alongside compiled JS (helps tooling).
    "declaration": true,
    // Strip comments from emitted JS (comments stay in your .ts source).
    "removeComments": true,
    // Required for NestJS dependency injection (@Injectable(), reflect metadata).
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    // Compile to ES2021 syntax — supported by Node 20+ (our host runtime).
    "target": "ES2021",
    "sourceMap": true,
    // Compiled JavaScript lands here; gitignored, produced by `npm run build`.
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    // Skip type-checking of .d.ts inside node_modules (faster builds).
    "skipLibCheck": true,

    // ── Strict typing (Master Plan §4 / P4 — non-negotiable) ────────────────
    // "strict": true turns ON the whole strict family at once:
    //   noImplicitAny, strictNullChecks, strictFunctionTypes, strictBindCallApply,
    //   strictPropertyInitialization, noImplicitThis, useUnknownInCatchVariables, alwaysStrict
    // Lazarus requires this so bugs are caught at compile time, not in production.
    "strict": true,
    // Repeated explicitly because Master Plan §6.2 Step 1.3 calls it out by name.
    // (Redundant with "strict": true — kept for audit clarity.)
    "noImplicitAny": true,

    // ── Additional safety (not part of the "strict" umbrella) ───────────────
    // Catch accidental fall-through in switch statements.
    "noFallthroughCasesInSwitch": true,
    // Import paths must match file casing exactly (important on Linux VPS vs Windows dev).
    "forceConsistentCasingInFileNames": true
  }
}
