{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,

    // Master Plan P4 — strict typing non-negotiable end-to-end.
    "strict": true,
    "noImplicitAny": true,

    "noFallthroughCasesInSwitch": true,
    // Catches path-casing drift between Windows dev and Linux VPS deploy.
    "forceConsistentCasingInFileNames": true
  }
}
